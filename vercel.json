{
  "version": 2,
  "builds": [
    {
      "src": "api/check_flag.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/check_flag",
      "dest": "/api/check_flag.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}